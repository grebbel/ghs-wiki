    {"id":"t-B-body","type":"text","x":455,"y":135,"width":310,"height":300,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":8,"version":1,"versionNonce":8,"isDeleted":false,"boundElements":[],"updated":1747200000000,"link":null,"locked":false,"text":"Zotero wordt SoT voor\nwiki/sources/-citaties.\nBibliografischeBron-schema\n→ wiki source frontmatter.\n\nSync schrijft direct wiki/\nsources/-pagina's (stubs).\nClaude vult body+links.\n\nDelta tov vandaag:\n• Schema-mapping\n• Two-way conflict policy\n• Hook: lint frontmatter-\n  drift Zotero ↔ git\n\nWaarheid wordt verdeeld:\nZotero voor citatie,\ngit voor narratief.","fontSize":13,"fontFamily":1,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Zotero wordt SoT voor\nwiki/sources/-citaties.\nBibliografischeBron-schema\n→ wiki source frontmatter.\n\nSync schrijft direct wiki/\nsources/-pagina's (stubs).\nClaude vult body+links.\n\nDelta tov vandaag:\n• Schema-mapping\n• Two-way conflict policy\n• Hook: lint frontmatter-\n  drift Zotero ↔ git\n\nWaarheid wordt verdeeld:\nZotero voor citatie,\ngit voor narratief.","lineHeight":1.4},
